# Environment Variables — Nexus Backend

# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (free tier works fine)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Nexus-git

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — keep this private
JWT_SECRET_KEY=change_me_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of your frontend dev server (Vite default)
FRONTEND_URL=http://localhost:5173

# ── VCS Engine ────────────────────────────────────────────────────────────────
# Absolute path to the directory Nexus will track as a repository
# This is where .ourGit/ will be created on `node cli.js init`
VCS_WORKSPACE_ROOT=C:\path\to\your\demo-workspace

# ── AI (optional — app works without this) ────────────────────────────────────
# OpenAI API key for diff explanation + commit message suggestion
OPENAI_API_KEY=sk-proj-...

# Model to use for AI features (gpt-4o-mini is fastest and cheapest)
OPENAI_MODEL=gpt-4o-mini

# Provider switch: "openai" or "gemini"
AI_PROVIDER=openai
